[Unit]
Description=CANlogger waveform capture service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/CANlogger/backend
ExecStart=/opt/CANlogger/backend/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
User=canlogger
Group=canlogger

[Install]
WantedBy=multi-user.target
