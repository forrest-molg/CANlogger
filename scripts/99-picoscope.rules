# PicoTech PicoScope USB access rules
# Vendor ID 0ce9 covers all PicoScope models (2000/3000/4000/5000/6000 series).
# Grants read/write access to any member of the 'plugdev' group,
# which Docker containers running as root inherit via the --privileged flag.
SUBSYSTEM=="usb", ATTRS{idVendor}=="0ce9", MODE="0666", GROUP="plugdev"
